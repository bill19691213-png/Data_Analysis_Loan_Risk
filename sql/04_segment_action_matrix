CREATE OR REPLACE TABLE `project.dataset.segment_action_matrix` AS
WITH segment_summary AS (
    SELECT
        grade,
        term_months,
        purpose,

        COUNT(*) AS loan_count,
        SUM(funded_amnt) AS funded_amount,
        SAFE_DIVIDE(SUM(is_default), COUNT(*)) AS default_rate,
        AVG(int_rate) AS avg_interest_rate,
        SUM(defaulted_funded_amount) AS defaulted_funded_amount
    FROM `project-cf626adc-1290-4ce9-aae.Leading_Club.loan_risk_feature_base`
    GROUP BY grade, term_months, purpose
    HAVING COUNT(*) >= 100
),

portfolio_avg AS (
    SELECT
        SAFE_DIVIDE(SUM(is_default), COUNT(*)) AS portfolio_default_rate,
        AVG(int_rate) AS portfolio_avg_interest_rate,
        SUM(funded_amnt) AS total_funded_amount,
        SUM(defaulted_funded_amount) AS total_defaulted_funded_amount
    FROM `project-cf626adc-1290-4ce9-aae.Leading_Club.loan_risk_feature_base`
)

SELECT
    s.grade,
    s.term_months,
    s.purpose,
    s.loan_count,
    s.funded_amount,
    ROUND(s.default_rate * 100, 2) AS default_rate_pct,
    ROUND(s.avg_interest_rate, 2) AS avg_interest_rate_pct,
    s.defaulted_funded_amount,

    ROUND(SAFE_DIVIDE(s.funded_amount, p.total_funded_amount) * 100, 2) AS portfolio_share_pct,
    ROUND(SAFE_DIVIDE(s.defaulted_funded_amount, p.total_defaulted_funded_amount) * 100, 2) AS loss_share_pct,

    ROUND(
        (
            SAFE_DIVIDE(s.defaulted_funded_amount, p.total_defaulted_funded_amount)
            - SAFE_DIVIDE(s.funded_amount, p.total_funded_amount)
        ) * 100,
        2
    ) AS excess_loss_share_pct,

    CASE
        WHEN s.default_rate > p.portfolio_default_rate
             AND SAFE_DIVIDE(s.defaulted_funded_amount, p.total_defaulted_funded_amount)
                 > SAFE_DIVIDE(s.funded_amount, p.total_funded_amount)
             AND s.avg_interest_rate <= p.portfolio_avg_interest_rate
        THEN 'Tighten or Reprice'

        WHEN s.default_rate > p.portfolio_default_rate
             AND SAFE_DIVIDE(s.defaulted_funded_amount, p.total_defaulted_funded_amount)
                 > SAFE_DIVIDE(s.funded_amount, p.total_funded_amount)
        THEN 'Deprioritize / Tighten'

        WHEN s.default_rate > p.portfolio_default_rate
        THEN 'Monitor'

        ELSE 'Maintain'
    END AS action_flag

FROM segment_summary s
CROSS JOIN portfolio_avg p
ORDER BY excess_loss_share_pct DESC, defaulted_funded_amount DESC;
